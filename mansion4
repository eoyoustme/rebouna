---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")

	local cc = game.Lighting:FindFirstChild("MainColorCorrection")
	if cc then
		cc.TintColor = Color3.fromRGB(255, 255, 255)
		cc.Contrast = 0.2
		TweenService:Create(cc, TweenInfo.new(2.5), {Contrast = 0}):Play()
		TweenService:Create(cc, TweenInfo.new(5), {TintColor = Color3.fromRGB(0, 0, 255)}):Play()
	end
end)

entity:SetCallback("OnStartMoving", function()
	print("Entity has started moving")
end)

entity:SetCallback("OnEnterRoom", function(room, firstTime)
	if firstTime then
		print("Entity has entered room: ".. room.Name.. " for the first time")
	else
		print("Entity has entered room: ".. room.Name.. " again")
	end
end)

entity:SetCallback("OnLookAt", function(lineOfSight)
	if lineOfSight then
		print("Player is looking at entity")
	else
		print("Player view is obstructed by something")
	end
end)

entity:SetCallback("OnRebounding", function(startOfRebound)
	if startOfRebound then
		print("Entity has started rebounding")
	else
		print("Entity has finished rebounding")
	end
end)

entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")

	task.wait(2)
	local cc = game.Lighting:FindFirstChild("MainColorCorrection")
	if cc then
		cc.TintColor = Color3.fromRGB(0, 0, 255)
		cc.Contrast = 0.2
		TweenService:Create(cc, TweenInfo.new(2.5), {Contrast = 0}):Play()
		TweenService:Create(cc, TweenInfo.new(5), {TintColor = Color3.fromRGB(255, 255, 255)}):Play()
	end
end)

entity:SetCallback("OnDespawned", function()
	print("Entity has despawned")
end)

local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

task.spawn(function()
    local player = Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    local humanoid = character:WaitForChild("Humanoid")
    local camera = workspace.CurrentCamera

    local entityModel = workspace:WaitForChild("mansion")
    local primaryPart = entityModel:FindFirstChild("RushNew")
    if not primaryPart then return end

    -- Khoá camera để điều khiển thủ công
    camera.CameraType = Enum.CameraType.Scriptable

    -- Kết nối camera: theo người chơi, luôn nhìn về entity
    local camLock
    camLock = RunService.RenderStepped:Connect(function()
        if not primaryPart or not primaryPart.Parent or not humanoidRootPart or not humanoidRootPart.Parent then
            if camLock then camLock:Disconnect() end
            return
        end

        local camOffset = Vector3.new(0, 5, 10) -- vị trí lệch phía sau người chơi
        local cameraPosition = humanoidRootPart.Position + camOffset
        local lookAt = primaryPart.Position

        camera.CFrame = CFrame.lookAt(cameraPosition, lookAt)
    end)

    -- Tải và phát âm thanh từ GitHub
    local function GetGitSound(githubURL, soundName)
        if not isfile(soundName .. ".mp3") then
            writefile(soundName .. ".mp3", game:HttpGet(githubURL))
        end
        local sound = Instance.new("Sound")
        sound.SoundId = (getcustomasset or getsynasset)(soundName .. ".mp3")
        sound.Volume = 3
        sound.Parent = workspace
        sound:Play()
        return sound
    end

    -- Entity liên tục tween đuổi theo người chơi
    local chasing = true
    task.spawn(function()
        while chasing and primaryPart and primaryPart.Parent and humanoidRootPart and humanoidRootPart.Parent do
            local targetCFrame = humanoidRootPart.CFrame
            local tween = TweenService:Create(primaryPart, TweenInfo.new(150000, Enum.EasingStyle.Quad), {CFrame = targetCFrame})
            tween:Play()
            tween.Completed:Wait()

            -- Kiểm tra khoảng cách
            local distance = (primaryPart.Position - humanoidRootPart.Position).Magnitude
            if distance <= 5 then
                chasing = false

                -- Phát âm thanh jumpscare
                local sound = GetGitSound("https://github.com/eoyoustme/rebouna/blob/main/Kill_with_static.mp3?raw=true", "mansion_Jumpscare")

                -- Delay 1 tí để âm thanh chơi lên rồi giết
                task.wait(0.5)

                humanoid.Health = 0

                -- Dừng camera lock
                if camLock then camLock:Disconnect() end

                -- Reset camera
                camera.CameraType = Enum.CameraType.Custom

                -- Optionally: xoá entity
                entityModel:Destroy()
                break
            end
        end
    end)
end)

---====== Run entity ======---

if entity then
	entity:Run()
else
	warn("Entity creation failed!")
end
