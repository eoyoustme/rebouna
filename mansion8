---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")

	local cc = game.Lighting:FindFirstChild("MainColorCorrection")
	if cc then
		cc.TintColor = Color3.fromRGB(255, 255, 255)
		cc.Contrast = 0.2
		TweenService:Create(cc, TweenInfo.new(2.5), {Contrast = 0}):Play()
		TweenService:Create(cc, TweenInfo.new(5), {TintColor = Color3.fromRGB(0, 0, 255)}):Play()
	end
end)

entity:SetCallback("OnStartMoving", function()
	print("Entity has started moving")
end)

entity:SetCallback("OnEnterRoom", function(room, firstTime)
	if firstTime then
		print("Entity has entered room: ".. room.Name.. " for the first time")
	else
		print("Entity has entered room: ".. room.Name.. " again")
	end
end)

entity:SetCallback("OnLookAt", function(lineOfSight)
	if lineOfSight then
		print("Player is looking at entity")
	else
		print("Player view is obstructed by something")
	end
end)

entity:SetCallback("OnRebounding", function(startOfRebound)
	if startOfRebound then
		print("Entity has started rebounding")
	else
		print("Entity has finished rebounding")
	end
end)

entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")

	task.wait(2)
	local cc = game.Lighting:FindFirstChild("MainColorCorrection")
	if cc then
		cc.TintColor = Color3.fromRGB(0, 0, 255)
		cc.Contrast = 0.2
		TweenService:Create(cc, TweenInfo.new(2.5), {Contrast = 0}):Play()
		TweenService:Create(cc, TweenInfo.new(5), {TintColor = Color3.fromRGB(255, 255, 255)}):Play()
	end
end)

entity:SetCallback("OnDespawned", function()
	print("Entity has despawned")
end)

-- Define TweenService, which is required for the entity following behavior.
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

-- Set up a callback for when the entity damages the player.
entity:SetCallback("OnDamagePlayer", function(newHealth)
	-- Check if the player's health has reached zero.
	if newHealth == 0 then
		print("Entity has killed the player")
	else
		print("Entity has damaged the player")

		-- Spawn a new coroutine to handle the entity's actions after damaging the player.
		task.spawn(function()
			local player = Players.LocalPlayer
			-- Wait for the player's character to load.
			local character = player.Character or player.CharacterAdded:Wait()
			-- Wait for the humanoid and humanoidRootPart to be available in the character.
			local humanoid = character:WaitForChild("Humanoid", 5)
			local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
			local camera = workspace.CurrentCamera -- Lấy camera hiện tại

			-- Get the entity model and its primary part.
			-- The entity model is now "B-60" and its primary part is "RushNew" as per your request.
			local entityModel = workspace:WaitForChild("mansion")
			local primaryPart = entityModel:FindFirstChild("RushNew")

			-- If any essential parts are missing, exit the function.
			if not (entityModel and humanoid and humanoidRootPart and primaryPart and camera) then return end

			-- Variable to control the entity following loop.
			local to = true
			-- Spawn a new coroutine for the entity to follow the player.
			task.spawn(function()
				-- Continue following as long as 'to' is true and the parts exist.
				while to and primaryPart.Parent and humanoidRootPart.Parent do
					local targetCFrame = humanoidRootPart.CFrame
					-- Create a tween to smoothly move the entity towards the player.
					local tween = TweenService:Create(primaryPart, TweenInfo.new(20000000, Enum.EasingStyle.Quad), {CFrame = targetCFrame})
					tween:Play()
					-- Wait for the tween to complete before the next iteration.
					tween.Completed:Wait()
				end
			end)

			-- Khóa camera theo hướng nhìn vào entity khi jumpscare
			camera.CameraType = Enum.CameraType.Scriptable

			local lockConnection
			lockConnection = RunService.RenderStepped:Connect(function()
				-- Đảm bảo primaryPart và parent của nó vẫn tồn tại
				if not primaryPart or not primaryPart.Parent then
					if lockConnection then lockConnection:Disconnect() end
					return
				end
				-- Camera sẽ nhìn vào vị trí của primaryPart (RushNew)
				camera.CFrame = CFrame.lookAt(camera.CFrame.Position, primaryPart.Position)
			end)

			-- Function to get and play a sound from a GitHub URL.
			local function GetGitSound(GithubSnd, SoundName)
				local url = GithubSnd
				-- Check if the sound file already exists locally.
				if not isfile(SoundName .. ".mp3") then
					-- If not, download and save it.
					writefile(SoundName .. ".mp3", game:HttpGet(url))
				end
				-- Create a new Sound instance.
				local sound = Instance.new("Sound")
				-- Set the SoundId using the custom asset path.
				sound.SoundId = (getcustomasset or getsynasset)(SoundName .. ".mp3")
				sound.Volume = 3 -- Set the volume.
				sound.Parent = workspace -- Parent the sound to workspace so it can be played.
				sound:Play() -- Play the sound.
				return sound
			end

			-- Play the jumpscare sound.
			local crashSound = GetGitSound("https://github.com/eoyoustme/rebouna/blob/main/Kill_with_static.mp3?raw=true", "Crashund")

			-- Wait for 3 seconds.
			task.wait(3)

			-- Stop the entity following loop.
			to = false

			-- If the humanoid still exists, set its health to 0 to kill the player.
			if humanoid then humanoid.Health = 0 end
			-- If the entity model still exists, destroy it.
			if entityModel and entityModel.Parent then
				entityModel:Destroy()
			end

			-- Reset camera after the jumpscare and entity destruction.
			if lockConnection then
				lockConnection:Disconnect()
			end
			camera.CameraType = Enum.CameraType.Custom
		end)
	end
end)

---====== Run entity ======---

if entity then
	entity:Run()
else
	warn("Entity creation failed!")
end
