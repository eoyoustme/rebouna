---====== Debug entity ======---

entity:SetCallback("OnSpawned", function()
	print("Entity has spawned")

	local cc = game.Lighting:FindFirstChild("MainColorCorrection")
	if cc then
		cc.TintColor = Color3.fromRGB(255, 255, 255)
		cc.Contrast = 0.2
		TweenService:Create(cc, TweenInfo.new(2.5), {Contrast = 0}):Play()
		TweenService:Create(cc, TweenInfo.new(5), {TintColor = Color3.fromRGB(0, 0, 255)}):Play()
	end
end)

entity:SetCallback("OnStartMoving", function()
	print("Entity has started moving")
end)

entity:SetCallback("OnEnterRoom", function(room, firstTime)
	if firstTime then
		print("Entity has entered room: ".. room.Name.. " for the first time")
	else
		print("Entity has entered room: ".. room.Name.. " again")
	end
end)

entity:SetCallback("OnLookAt", function(lineOfSight)
	if lineOfSight then
		print("Player is looking at entity")
	else
		print("Player view is obstructed by something")
	end
end)

entity:SetCallback("OnRebounding", function(startOfRebound)
	if startOfRebound then
		print("Entity has started rebounding")
	else
		print("Entity has finished rebounding")
	end
end)

entity:SetCallback("OnDespawning", function()
	print("Entity is despawning")

	task.wait(2)
	local cc = game.Lighting:FindFirstChild("MainColorCorrection")
	if cc then
		cc.TintColor = Color3.fromRGB(0, 0, 255)
		cc.Contrast = 0.2
		TweenService:Create(cc, TweenInfo.new(2.5), {Contrast = 0}):Play()
		TweenService:Create(cc, TweenInfo.new(5), {TintColor = Color3.fromRGB(255, 255, 255)}):Play()
	end
end)

entity:SetCallback("OnDespawned", function()
	print("Entity has despawned")
end)

local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")

entity:SetCallback("OnDamagePlayer", function(newHealth)
	if newHealth == 0 then
		print("Entity has killed the player")
	else
		print("Entity has damaged the player")

		task.spawn(function()
			local player = Players.LocalPlayer
			local character = player.Character or player.CharacterAdded:Wait()
			local humanoid = character:WaitForChild("Humanoid", 5)
			local humanoidRootPart = character:WaitForChild("HumanoidRootPart", 5)
			local camera = workspace.CurrentCamera

			local entityModel = workspace:FindFirstChild("mansion")
			if not (entityModel and humanoid and humanoidRootPart and camera) then return end

			local entityPrimaryPart = entityModel:FindFirstChild("RushNew") or entityModel.PrimaryPart
			if not entityPrimaryPart then return end

			-- Hàm tween di chuyển entity tới vị trí target (ở đây là người chơi)
			local function Moving(targetCFrame, dur)
				local tween_info = TweenInfo.new(dur, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
				local tween = TweenService:Create(entityPrimaryPart, tween_info, {CFrame = targetCFrame})
				tween:Play()
				tween.Completed:Wait()
			end

			-- Entity bay tới người chơi trong 4 giây
			Moving(humanoidRootPart.CFrame, 400000)

			-- Khóa camera, giữ vị trí camera gốc, nhìn về entity
			local originalCameraPosition = camera.CFrame.Position
			camera.CameraType = Enum.CameraType.Scriptable

			local lockConnection
			lockConnection = game:GetService("RunService").RenderStepped:Connect(function()
				if not entityPrimaryPart or not entityPrimaryPart.Parent then
					lockConnection:Disconnect()
					return
				end

				camera.CFrame = CFrame.lookAt(originalCameraPosition, entityPrimaryPart.Position)
			end)

			-- Phát âm thanh jumpscare
			local function GetGitSound(GithubSnd, SoundName)
				local url = GithubSnd
				if not isfile(SoundName .. ".mp3") then
					writefile(SoundName .. ".mp3", game:HttpGet(url))
				end
				local sound = Instance.new("Sound")
				sound.SoundId = (getcustomasset or getsynasset)(SoundName .. ".mp3")
				sound.Volume = 3
				sound.Parent = workspace
				sound:Play()
				return sound
			end

			local crashSound = GetGitSound("https://github.com/eoyoustme/rebouna/blob/main/Kill_with_static.mp3?raw=true", "Crashund")

			-- Đợi 3 giây rồi giết player và xoá entity
			task.wait(3)
			if humanoid then humanoid.Health = 0 end
			if entityModel and entityModel.Parent then
				entityModel:Destroy()
			end

			-- Reset camera
			if lockConnection then
				lockConnection:Disconnect()
			end
			camera.CameraType = Enum.CameraType.Custom
		end)
	end
end)

---====== Run entity ======---

if entity then
	entity:Run()
else
	warn("Entity creation failed!")
end
