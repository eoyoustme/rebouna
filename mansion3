entity:SetCallback("OnDamagePlayer", function(newHealth)
	if newHealth == 0 then
		print("Entity has killed the player")
	else
		print("Entity has damaged the player")
task.spawn(function()
                    local player = Players.LocalPlayer
                    local character = player.Character or player.CharacterAdded:Wait()
                    local humanoidRootPart = character:WaitForChild("HumanoidRootPart")
                    local entityModel = workspace:WaitForChild("mansion")
                    local primaryPart = entityModel:FindFirstChild("RushNew")
                    if not primaryPart then return end

                    -- Entity follows player
                    local to = true
                    task.spawn(function()
                        while to and primaryPart.Parent and humanoidRootPart do
                            local targetCFrame = humanoidRootPart.CFrame
                            local tween = TweenService:Create(primaryPart, TweenInfo.new(2000, Enum.EasingStyle.Quad), {CFrame = targetCFrame})
                            tween:Play()
                            tween.Completed:Wait()
                        end
                    end)

wait(2)
 local function GetGitSound(GithubSnd, SoundName)
            local url = GithubSnd
            if not isfile(SoundName .. ".mp3") then
                writefile(SoundName .. ".mp3", game:HttpGet(url))
            end
            local sound = Instance.new("Sound")
            sound.SoundId = (getcustomasset or getsynasset)(SoundName .. ".mp3")
            return sound
        end

        local crash = GetGitSound("https://github.com/eoyoustme/rebouna/blob/main/Kill_with_static.mp3.mpeg.wav?raw=true", "Crashund")
        crash.Volume = 3
        crash.Parent = workspace
        crash.PlaybackSpeed = 1
        crash:Play()

	end
end)

